        "hashedPassword": [
            "$6$mainsalt$mainpasswordhashforrecoveryuser"
        ],
        "recoveryKey": [
            {
                "type": "modhex64",
                "hashedPassword": "$6$recovery1$hashedrecoverykey1"
            },
            {
                "type": "modhex64",
                "hashedPassword": "$6$recovery2$hashedrecoverykey2"
            }
        ]
    }
}
