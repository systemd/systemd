# do not edit this file, it will be overwritten on update

# USB devices INTEGRATION variable: Could be internal if the device is inherent part of the system or external otherwise.
# The variable is set of all usb devices by checking the removable attribute of the usb port it's connected.
# This must loaded after 60-persistent-*.rules to have ID_BUS.
ENV{ID_BUS}=="usb", DRIVERS=="usb", ATTRS{maxchild}=="0", ATTRS{removable}=="fixed", ENV{INTEGRATION}="internal"
ENV{ID_BUS}=="usb", DRIVERS=="usb", ATTRS{maxchild}=="0", ATTRS{removable}=="removable|unknown", ENV{INTEGRATION}="external"

# libinput compatibility variables (actually is only known how to determite integration for usb ports,
# if integration is implemented for other kind of buses, this should go into its own file)
ENV{ID_INPUT_KEYBOARD}=="1", ENV{ID_INPUT_KEYBOARD_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_KEY}=="1", ENV{ID_INPUT_KEY_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_MOUSE}=="1", ENV{ID_INPUT_MOUSE_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_TRACKPOINT}=="1", ENV{ID_INPUT_TRACKPOINT_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_TOUCHPAD}=="1", ENV{ID_INPUT_TOUCHPAD_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_TOUCHSCREEN}=="1", ENV{ID_INPUT_TOUCHSCREEN_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_TABLET}=="1", ENV{ID_INPUT_TABLET_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_JOYSTICK}=="1", ENV{ID_INPUT_JOYSTICK_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_ACCELEROMETER}=="1", ENV{ID_INPUT_ACCELEROMETER_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_3D_MOUSE}=="1", ENV{ID_INPUT_3D_MOUSE_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_TRACKBALL}=="1", ENV{ID_INPUT_TRACKBALL_INTEGRATION}="$env{INTEGRATION}"
ENV{ID_INPUT_POINTINGSTICK}=="1", ENV{ID_INPUT_POINTINGSTICK_INTEGRATION}="$env{INTEGRATION}"
