# do not edit this file, it will be overwritten on update

ACTION=="remove", GOTO="persistent_u3v_end"
SUBSYSTEM!="usb", GOTO="persistent_u3v_end"

ATTRS{bDeviceClass}=="ef", ATTRS{bDeviceSubClass}=="02", ATTRS{bDeviceProtocol}=="01", \
        ENV{ID_USB_INTERFACES}=="*:ef0500:*", \
        IMPORT{builtin}="usb_id", IMPORT{builtin}="path_id"

ATTRS{bDeviceClass}=="ef", ATTRS{bDeviceSubClass}=="02", ATTRS{bDeviceProtocol}=="01", \
        ENV{ID_USB_INTERFACES}=="*:ef0500:*", ENV{ID_SERIAL}=="?*", \
        GROUP="video", \
        SYMLINK+="u3v/by-id/$env{ID_SERIAL}"

ATTRS{bDeviceClass}=="ef", ATTRS{bDeviceSubClass}=="02", ATTRS{bDeviceProtocol}=="01", \
        ENV{ID_USB_INTERFACES}=="*:ef0500:*", ENV{ID_PATH}=="?*", \
        SYMLINK+="u3v/by-path/$env{ID_PATH}"

LABEL="persistent_u3v_end"
