# do not edit this file, it will be overwritten on update

ACTION=="remove", GOTO="persistent_u3v_end"
SUBSYSTEM!="usb", GOTO="persistent_u3v_end"
ENV{DEVTYPE}!="usb_device", GOTO="persistent_u3v_end"

ATTR{bDeviceClass}!="ef", GOTO="persistent_u3v_end"
ATTR{bDeviceSubClass}!="02", GOTO="persistent_u3v_end"
ATTR{bDeviceProtocol}!="01", GOTO="persistent_u3v_end"
ENV{ID_USB_INTERFACES}!="*:ef0500:*", GOTO="persistent_u3v_end"

IMPORT{builtin}="usb_id"
IMPORT{builtin}="path_id"

TAG+="uaccess"

ENV{ID_SERIAL}=="?*", SYMLINK+="u3v/by-id/$env{ID_SERIAL}"
ENV{ID_PATH}=="?*",   SYMLINK+="u3v/by-path/$env{ID_PATH}"

LABEL="persistent_u3v_end"
