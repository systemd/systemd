[Unit]
Description=TPM PCR OS Separator
Documentation=man:systemd-pcrosseparator.service(8)
DefaultDependencies=no
Conflicts=shutdown.target initrd-switch-root.target
After=tpm2.target
Before=sysinit.target shutdown.target initrd-switch-root.target cryptsetup-pre.target cryptsetup.target
ConditionPathExists=/etc/initrd-release
ConditionSecurity=measured-os
FailureAction=reboot-force

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart={{LIBEXECDIR}}/systemd-pcrextend --graceful \
                --pcr=0 --pcr=1 --pcr=2 --pcr=3 --pcr=4 --pcr=5 \
                --pcr=6 --pcr=7 --pcr=9 --pcr=12 --pcr=13 --pcr=14 \
                --event-type=os-separator \
                os-separator
