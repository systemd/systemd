[Unit]
Description=Enable Pre-IMDS Networking (Locked IMDS Access)
Documentation=man:systemd-imds-early-network.service(8)
DefaultDependencies=no
Before=network-pre.target
Wants=network-pre.target
Conflicts=shutdown.target initrd-switch-root.target
Before=shutdown.target initrd-switch-root.target

[Service]
Type=oneshot
RemainAfterExit=yes
StandardInputText=L /run/systemd/network/85-imds-early.network - - - - {{LIBEXECDIR}}/imds/85-imds-early.network
ExecStart=systemd-tmpfiles --create -
