[Unit]
Description=Grant systemd-networkd access to the Open vSwitch database socket
Documentation=man:networkd.conf(5)
# setfacl(1) is provided by the acl package; on minimal images that lack it, skip this
# unit gracefully instead of failing (the requirement is documented in networkd.conf(5)).
ConditionPathExists=/usr/bin/setfacl
# The .path unit triggers us via PathModified=, which also fires on the socket's removal
# (ovsdb-server unlinks the old inode before bind()ing the new one). Skip that transient
# no-socket trigger cleanly via a condition instead of letting setfacl fail on the missing
# path; the follow-up create fires us again with the socket present.
ConditionPathExists=/run/openvswitch/db.sock

[Service]
Type=oneshot
# systemd-networkd runs as the unprivileged "systemd-network" user and must be able
# to traverse the runtime directory and connect to (i.e. write) the OVSDB socket. A
# per-user ACL grants exactly that, independent of the socket's owning group and mode,
# which vary across distributions. Requires setfacl(1) from the acl package.
#
# Grant only traverse (x) on the directory — read (r) would let systemd-network
# enumerate /run/openvswitch (pidfiles, control sockets, conf.db), which it never
# needs to reach the known db.sock path. /run/openvswitch is created and owned by
# the (root) Open vSwitch daemon, so planting a hostile db.sock symlink there would
# already require root; we therefore do not attempt symlink hardening here (setfacl
# -P would not help anyway — on a non-recursive symlink argument it applies no ACL
# at all, silently breaking legitimately symlinked sockets).
ExecStart=/usr/bin/setfacl -m u:systemd-network:x /run/openvswitch
ExecStart=/usr/bin/setfacl -m u:systemd-network:rw /run/openvswitch/db.sock
