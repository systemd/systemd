[Unit]
Description=PTY Broker
Documentation=man:systemd-ptybrokerd.service(8)
Requires=systemd-ptybrokerd.socket
After=systemd-ptybrokerd.socket

[Service]
ExecStart={{LIBEXECDIR}}/systemd-ptybrokerd --user
Type=notify
Restart=on-failure
RestartSec=0
{{SERVICE_WATCHDOG}}

[Install]
Also=systemd-ptybrokerd.socket
