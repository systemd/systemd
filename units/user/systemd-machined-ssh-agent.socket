[Unit]
Description=SSH agent for VMs registered with systemd-machined
Documentation=man:systemd-machined.service(8)
PartOf=systemd-machined.service

[Socket]
ListenStream=%t/systemd/machine/ssh-agent
FileDescriptorName=ssh-agent
SocketMode=0600
RemoveOnStop=yes
Service=systemd-machined.service
