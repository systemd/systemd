option --luks-sector-size=BYTES
group luks_properties
help Sector size for LUKS encryption in bytes
        r = parse_sector_size_field(match_identity ?: &arg_identity_extra, "luksSectorSize", optarg);
        if (r < 0)
                return r;

option --auto-resize-mode=MODE
group luks_properties
help Automatically grow/shrink home on login/logout
        r = parse_auto_resize_mode_field(match_identity ?: &arg_identity_extra,
                                         "autoResizeMode", optarg);
        if (r < 0)
                return r;

option --rebalance-weight=WEIGHT
group luks_properties
help Weight while rebalancing
        r = parse_rebalance_weight(match_identity ?: &arg_identity_extra,
                                   "rebalanceWeight", optarg);
        if (r < 0)
                return r;

option --nosuid=yes|no
group mount_properties
help Control the 'nosuid' flag of the home mount
        _fallthrough_;
option --nodev=yes|no
group mount_properties
help Control the 'nodev' flag of the home mount
        _fallthrough_;
option --noexec=yes|no
group mount_properties
help Control the 'noexec' flag of the home mount
        _fallthrough_;
option --locked=yes|no
group user_account_properties
help Set locked account state
        _fallthrough_;
option --kill-processes=yes|no
group login_properties
help Whether to kill user processes when sessions terminate
        _fallthrough_;
option --auto-login=yes|no
group login_properties
help Try to log this user in automatically
        _fallthrough_;
option --enforce-password-policy=yes|no
group password_policy
help Control whether to enforce system password policy for this user
        _fallthrough_;
option --password-change-now=yes|no
group password_policy
help Require the password to be changed on next login
        const char *field =
                                 c == ARG_LOCKED ? "locked" :
                                 c == ARG_NOSUID ? "mountNoSuid" :
                                  c == ARG_NODEV ? "mountNoDevices" :
                                 c == ARG_NOEXEC ? "mountNoExecute" :
                         c == ARG_KILL_PROCESSES ? "killProcesses" :
                             c == ARG_AUTO_LOGIN ? "autoLogin" :
                c == ARG_ENFORCE_PASSWORD_POLICY ? "enforcePasswordPolicy" :
                    c == ARG_PASSWORD_CHANGE_NOW ? "passwordChangeNow" :
                                                   NULL;
        assert(field);

        r = parse_boolean_field(match_identity ?: &arg_identity_extra, field, optarg);
        if (r < 0)
                return r;

option -P
group password_policy
help Same as --enforce-password-policy=no
        r = sd_json_variant_set_field_boolean(&arg_identity_extra, "enforcePasswordPolicy", false);
        if (r < 0)
                return log_error_errno(r, "Failed to set %s field: %m", "enforcePasswordPolicy");

option --match=this|other|any|auto
help To which machines to apply the settings
        if (streq(optarg, "any"))
                match_identity = &arg_identity_extra;
        else if (streq(optarg, "this"))
                match_identity = &arg_identity_extra_this_machine;
        else if (streq(optarg, "other"))
                match_identity = &arg_identity_extra_other_machines;
        else if (streq(optarg, "auto"))
                match_identity = NULL;
        else
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL),
                                       "--match= argument not understood. Refusing.");

option -A
help Same as --match=any
        match_identity = &arg_identity_extra;

option -T
help Same as --match=this
        match_identity = &arg_identity_extra_this_machine;

option -N
help Same as --match=other
        match_identity = &arg_identity_extra_other_machines;

outro
        if (!strv_isempty(languages)) {
                r = sd_json_variant_set_field_string(&arg_identity_extra, "preferredLanguage", languages[0]);
                if (r < 0)
                        return log_error_errno(r, "Failed to update preferred language: %m");

                char **additional = strv_skip(languages, 1);
                if (!strv_isempty(additional)) {
                        r = sd_json_variant_set_field_strv(&arg_identity_extra, "additionalLanguages", additional);
                        if (r < 0)
                                return log_error_errno(r, "Failed to update additional language list: %m");
                } else {
                        r = drop_from_identity("additionalLanguages");
                        if (r < 0)
                                return r;
                }
        }
