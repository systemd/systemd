global help_key_width 28

intro
        /* This points to one of arg_identity_extra, arg_identity_extra_this_machine,
         * arg_identity_extra_other_machines, in order to redirect changes on the next property
         * being set to this part of the identity, instead of the default. */
        sd_json_variant **match_identity = NULL;

        _cleanup_strv_free_ char **languages = NULL;

option -h --help

option --version

option --no-pager

option --no-legend
help Do not show the headers and footers
        arg_legend = false;

option --no-ask-password
help Do not ask for system passwords
        arg_ask_password = false;

option --offline
help Don't update record embedded in home directory
        arg_offline = true;

option -H= --host=[USER@]HOST
help Operate on remote host
        arg_transport = BUS_TRANSPORT_REMOTE;
        arg_host = optarg;

option -M= --machine=CONTAINER
help Operate on local container
        r = parse_machine_argument(optarg, &arg_host, &arg_transport);
        if (r < 0)
                return r;

option -I= --identity=PATH
help Read JSON identity from file
        arg_identity = optarg;

option --json=FORMAT
help Output inspection data in JSON (takes one of pretty, short, off)
        r = parse_json_argument(optarg, &arg_json_format_flags);
        if (r <= 0)
                return r;

option -j
help Equivalent to --json=pretty (on TTY) or --json=short (otherwise)
        arg_json_format_flags = SD_JSON_FORMAT_PRETTY_AUTO|SD_JSON_FORMAT_COLOR_AUTO;

option --export-format=full|stripped|minimal
help Strip JSON inspection data
        if (streq(optarg, "help"))
                return DUMP_STRING_TABLE(export_format, ExportFormat, _EXPORT_FORMAT_MAX);

        arg_export_format = export_format_from_string(optarg);
        if (arg_export_format < 0)
                return log_error_errno(arg_export_format, "Invalid export format: %s", optarg);

option -E
help Used once equals -j --export-format=stripped,
help used twice equals -j --export-format=minimal
        if (arg_export_format == EXPORT_FORMAT_FULL)
                arg_export_format = EXPORT_FORMAT_STRIPPED;
        else if (arg_export_format == EXPORT_FORMAT_STRIPPED)
                arg_export_format = EXPORT_FORMAT_MINIMAL;
        else
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL), "Specifying -E more than twice is not supported.");

        arg_json_format_flags &= ~SD_JSON_FORMAT_OFF;
        if (arg_json_format_flags == 0)
                arg_json_format_flags = SD_JSON_FORMAT_PRETTY_AUTO|SD_JSON_FORMAT_COLOR_AUTO;

option --key-name=NAME
help Key name when adding a signing key
        if (!isempty(optarg) && !filename_is_valid(optarg))
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL),
                                       "Parameter for --key-name= not a valid filename: %s", optarg);

        r = free_and_strdup_warn(&arg_key_name, empty_to_null(optarg));
        if (r < 0)
                return r;

option --seize=no
help Do not strip existing signatures of user record when creating
        r = parse_boolean_argument("--seize=", optarg, &arg_seize);
        if (r < 0)
                return r;

option --prompt-new-user
help firstboot: Query user interactively for user to create
        arg_prompt_new_user = true;

option --prompt-groups=no
help In first-boot mode, don't prompt for auxiliary group memberships
        r = parse_boolean_argument("--prompt-groups=", optarg, &arg_prompt_groups);
        if (r < 0)
                return r;

option --prompt-shell=no
help In first-boot mode, don't prompt for shells
        r = parse_boolean_argument("--prompt-shell=", optarg, &arg_prompt_shell);
        if (r < 0)
                return r;

option --chrome=no
help In first-boot mode, don't show colour bar at top and bottom of terminal
        r = parse_boolean_argument("--chrome=", optarg, &arg_chrome);
        if (r < 0)
                return r;

option --mute-console=yes
help In first-boot mode, tell kernel/PID 1 to not write to the console while running
        r = parse_boolean_argument("--mute-console=", optarg, &arg_mute_console);
        if (r < 0)
                return r;

option -c= --real-name=REALNAME --comment=
# last name is a compat alias to keep thing in sync with useradd(8)
group general_user_properties
help Real name for user
        if (!isempty(optarg) && !valid_gecos(optarg))
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL),
                                       "Invalid GECOS field '%s'.", optarg);

        r = parse_string_field(match_identity ?: &arg_identity_extra, "realName", optarg);
        if (r < 0)
                return r;

option --realm=REALM
group general_user_properties
help Realm to create user in
        r = parse_realm_field(&arg_identity_extra, "realm", optarg);
        if (r < 0)
                return r;

option --alias=ALIAS
group general_user_properties
help Define alias usernames for this account
        r = parse_group_field(arg_identity_extra, &arg_identity_extra, "aliases", optarg);
        if (r < 0)
                return r;

option --email-address=EMAIL
group general_user_properties
help Email address for user
        _fallthrough_;
option --location=LOCATION
group general_user_properties
help Set location of user on earth
        _fallthrough_;
option --icon-name=NAME
group general_user_properties
help Icon name for user
        _fallthrough_;
option --cifs-domain=DOMAIN
group cifs_properties
help CIFS (Windows) domain
        _fallthrough_;
option --cifs-user-name=USER
group cifs_properties
help CIFS (Windows) user name
        _fallthrough_;
option --cifs-service=SERVICE
group cifs_properties
help CIFS (Windows) service to mount as home area
        _fallthrough_;
option --cifs-extra-mount-options=OPTIONS
group cifs_properties
help CIFS (Windows) extra mount options
        _fallthrough_;
option --luks-extra-mount-options=OPTIONS
group luks_properties
help LUKS extra mount options
        _fallthrough_;
option --session-launcher=LAUNCHER
group login_properties
help Preferred session launcher file
        _fallthrough_;
option --session-type=TYPE
group login_properties
help Preferred session type
        const char *field =
                           c == ARG_EMAIL_ADDRESS ? "emailAddress" :
                                c == ARG_LOCATION ? "location" :
                               c == ARG_ICON_NAME ? "iconName" :
                             c == ARG_CIFS_DOMAIN ? "cifsDomain" :
                          c == ARG_CIFS_USER_NAME ? "cifsUserName" :
                            c == ARG_CIFS_SERVICE ? "cifsService" :
                c == ARG_CIFS_EXTRA_MOUNT_OPTIONS ? "cifsExtraMountOptions" :
                c == ARG_LUKS_EXTRA_MOUNT_OPTIONS ? "luksExtraMountOptions" :
                        c == ARG_SESSION_LAUNCHER ? "preferredSessionLauncher" :
                            c == ARG_SESSION_TYPE ? "preferredSessionType" :
                                                    NULL;
        assert(field);

        if (c == ARG_CIFS_SERVICE && !isempty(optarg)) {
                r = parse_cifs_service(optarg, NULL, NULL, NULL);
                if (r < 0)
                        return log_error_errno(r, "Failed to validate CIFS service name: %s", optarg);
        }

        r = parse_string_field(match_identity ?: &arg_identity_extra, field, optarg);
        if (r < 0)
                return r;

option -d= --home-dir=PATH
# compatible with useradd(8)
group general_user_properties
help Home directory
        r = parse_home_directory_field(&arg_identity_extra, "homeDirectory", optarg);
