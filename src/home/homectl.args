option --capability-ambient-set=CAPS
group general_user_properties
help Ambient POSIX capability set
        r = parse_capability_set_field(match_identity ?: &arg_identity_extra,
                                       &arg_capability_ambient_set,
                                       "capabilityAmbientSet", optarg);
        if (r < 0)
                return r;

option --access-mode=MODE
group general_user_properties
