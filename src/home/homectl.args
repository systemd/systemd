option --fs-type=TYPE
group luks_properties
help File system type to use in case of luks storage (btrfs, ext4, xfs)
        const char *field =
                                  c == ARG_STORAGE ? "storage" :
                                  c == ARG_FS_TYPE ? "fileSystemType" :
                                                     NULL;
        assert(field);

        sd_json_variant **identity = match_identity ?: &arg_identity_extra_this_machine;

        if (!isempty(optarg) && !string_is_safe(optarg))
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL),
                                       "Parameter for field %s not valid: %s", field, optarg);

        r = parse_string_field(identity, field, optarg);
        if (r < 0)
                return r;

