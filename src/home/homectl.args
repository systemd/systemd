option --skel=PATH -k=
# compatible with useradd(8)
group general_user_properties
help Skeleton directory to use
        _fallthrough_;
option --image-path=PATH
group storage_properties
help Path to image file/directory
        const char *field = c == 'k' ? "skeletonDirectory" : "imagePath";

        r = parse_path_field(match_identity ?: &arg_identity_extra_this_machine, field, optarg);
        if (r < 0)
