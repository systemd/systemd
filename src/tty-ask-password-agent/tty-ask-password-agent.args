# SPDX-License-Identifier: LGPL-2.1-or-later

option -h --help

option --version

option --list
help Show pending password requests
        arg_action = ACTION_LIST;

option --query
help Process pending password requests
        arg_action = ACTION_QUERY;

option --watch
help Continuously process password requests
        arg_action = ACTION_WATCH;

option --wall
help Continuously forward password requests to wall
        arg_action = ACTION_WALL;

option --plymouth
help Ask question with Plymouth instead of on TTY
        arg_plymouth = true;

option --console[=DEVICE]
help Ask question on /dev/console (or DEVICE if specified)
help instead of the current TTY
        if (optarg && isempty(optarg))
                return log_error_errno(SYNTHETIC_ERRNO(EINVAL),
                                       "Empty console device path is not allowed.");
        arg_console = true;
        r = free_and_strdup_warn(&arg_device, optarg);
        if (r < 0)
                return r;
